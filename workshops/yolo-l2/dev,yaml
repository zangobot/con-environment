apiVersion: v1
kind: Pod
metadata:
  name: yolo-notebook-dev
  namespace: default
  labels:
    app: yolo-notebook
spec:
  containers:
    - name: notebook
      image: ghcr.io/nbhdai/workshop-yolo-l2-notebook:latest
      imagePullPolicy: Always
      ports:
        - containerPort: 8888
      resources:
        limits:
          memory: "2Gi"
          cpu: "1"
---
apiVersion: v1
kind: Service
metadata:
  name: yolo-notebook-dev
  namespace: default
spec:
  type: NodePort
  selector:
    app: yolo-notebook
  ports:
    - port: 8888
      targetPort: 8888
      nodePort: 30888